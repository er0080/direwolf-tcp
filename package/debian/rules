#!/usr/bin/make -f
# dw-iface is a pure shell package — nothing to compile.
# tncattach is a runtime dependency installed separately (not in Ubuntu apt;
# build from https://github.com/markqvist/tncattach or use the Docker stage).

%:
	dh $@

override_dh_auto_build:
	@:

override_dh_auto_install:
	$(MAKE) install DESTDIR=$(CURDIR)/debian/dw-iface PREFIX=/usr
